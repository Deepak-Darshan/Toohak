{
    "scripts": {
        "test": "jest",
        "tsc": "tsc --project tsconfig.json",
        "lint": "eslint 'src/**/*.{ts,js}'",
        "lint-fix": "eslint --fix 'src/**/*.{ts,js}'",
        "start": "ts-node -T src/server.ts",
        "cleanup-sync-request": "pkill -f node_modules/sync-rpc/lib/worker.js > /dev/null 2>&1",
        "posttest": "npm run cleanup-sync-request || true",
        "ts-node-coverage": "nyc --reporter=text --reporter=lcov ts-node -T src/server.ts",
        "ts-node-dev": "ts-node-dev -T src/server.ts"
    },
    "dependencies": {
        "@upstash/redis": "^1.34.3",
        "bcrypt": "^5.1.1",
        "chance": "^1.1.12",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "morgan": "^1.10.0",
        "prompt-sync": "^4.2.0",
        "random-words": "^1.3.0",
        "slync": "^1.0.2",
        "sync-request": "^6.1.0",
        "ts-node": "^10.9.2",
        "validator": "^13.12.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/chance": "^1.1.6",
        "@types/cors": "^2.8.17",
        "@types/dotenv": "^8.2.3",
        "@types/express": "^4.17.21",
        "@types/http-errors": "^2.0.4",
        "@types/jest": "^29.5.12",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.14.7",
        "@types/prompt-sync": "^4.2.3",
        "@types/random-words": "^1.1.2",
        "@types/swagger-ui-express": "^4.1.6",
        "@types/validator": "^13.12.0",
        "@typescript-eslint/eslint-plugin": "^6.21.0",
        "@typescript-eslint/parser": "^6.21.0",
        "eslint": "^8.57.1",
        "eslint-plugin-jest": "^27.9.0",
        "jest": "^29.7.0",
        "nyc": "^15.1.0",
        "swagger-ui-express": "^5.0.1",
        "sync-request-curl": "^3.0.0",
        "ts-jest": "^29.2.5",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3",
        "yaml": "^2.4.5"
    },
    "nyc": {
